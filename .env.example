# ============================================================
# Manuscopy 配置 — Claude Agent SDK 驱动
# ============================================================

# 必填：Anthropic API key（或 Claude 代理服务的 key）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：当走 Claude 代理服务时，把请求转到代理的 base URL
# 官方 Anthropic 留空即可
# 国内 Claude 代理示例（按你买的代理填）：
#   ANTHROPIC_BASE_URL=https://api.your-claude-proxy.com
# ANTHROPIC_BASE_URL=

# 可选：模型名（默认 claude-sonnet-4-5）
# 可选：claude-opus-4-7 / claude-haiku-4-5 / claude-sonnet-4-5
# MANUSCOPY_MODEL=claude-sonnet-4-5

# 可选：存储路径
# MANUSCOPY_DATA_DIR=./data
# MANUSCOPY_WORKSPACES_DIR=./workspaces
