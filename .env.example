# ============================================================
# Manuscopy 配置 — Claude Agent SDK 驱动
# ============================================================

# 方式 A：官方 Anthropic
# 必填：Anthropic API key（或 Claude 代理服务的 key）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：当走 Claude 代理服务时，把请求转到代理的 base URL
# 官方 Anthropic 留空即可
# 国内 Claude 代理示例（按你买的代理填）：
#   ANTHROPIC_BASE_URL=https://api.your-claude-proxy.com
# ANTHROPIC_BASE_URL=

# 方式 B：国产大模型的 Claude Code / Anthropic 兼容接口
# 例如阿里百炼 Coding Plan 页面里的“兼容 Anthropic 接口协议工具”
# 这组变量会自动映射给 Claude Agent SDK 使用，优先级高于 ANTHROPIC_*。
# MANUSCOPY_CLAUDE_CODE_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# MANUSCOPY_CLAUDE_CODE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxx
# MANUSCOPY_CLAUDE_CODE_MODEL=按百炼页面可用模型名填写
#
# 如果你更喜欢短变量，也可以只填：
# ALIYUN_CODING_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# 可选：模型名（默认 claude-sonnet-4-5）
# 可选：claude-opus-4-7 / claude-haiku-4-5 / claude-sonnet-4-5
# 使用国产 Claude Code 兼容接口时，填平台页面列出的模型名。
# MANUSCOPY_MODEL=claude-sonnet-4-5

# 可选：存储路径
# MANUSCOPY_DATA_DIR=./data
# MANUSCOPY_WORKSPACES_DIR=./workspaces
